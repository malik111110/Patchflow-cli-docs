{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PatchFlow CLI",
  "description": "PatchFlow CLI is a local-first security scanner for modern engineering teams. It performs Software Composition Analysis (SCA), Static Application Security Testing (SAST), secret detection, reachability analysis, and framework-aware rule packs — all without a backend connection.",
  "colors": {
    "primary": "#2563eb",
    "light": "#3b82f6",
    "dark": "#1d4ed8"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "background": {
    "decoration": "gradient"
  },
  "metadata": {
    "timestamp": true
  },
  "search": {
    "prompt": "Search PatchFlow CLI docs..."
  },
  "banner": {
    "content": "PatchFlow CLI v0.1.3 — install script verification, containerized install test matrix, and clearer PATH setup. [View what's new →](/getting-started/release-notes)",
    "dismissible": true,
    "type": "info"
  },
  "variables": {
    "cliVersion": "0.1.3"
  },
  "contextual": {
    "display": "header",
    "options": [
      "assistant",
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode",
      "devin"
    ]
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/Patchflow-security/patchflow-cli"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/Patchflow-security/patchflow-cli"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Patchflow-security/patchflow-cli"
    },
    "links": [
      {
        "header": "Documentation",
        "items": [
          {
            "label": "Getting Started",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/getting-started/installation.md"
          },
          {
            "label": "User Guides",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/user-guides/scan.md"
          },
          {
            "label": "Reference",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/reference/commands.md"
          }
        ]
      },
      {
        "header": "Developers",
        "items": [
          {
            "label": "Architecture",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/developers/architecture.md"
          },
          {
            "label": "Framework Packs",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/developers/rule-packs.md"
          },
          {
            "label": "Benchmarks",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/developers/benchmarks.md"
          }
        ]
      },
      {
        "header": "Integrations",
        "items": [
          {
            "label": "GitHub Actions",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/integrations/github-actions.md"
          },
          {
            "label": "GitLab CI",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/integrations/gitlab.md"
          },
          {
            "label": "SARIF Uploads",
            "href": "https://github.com/Patchflow-security/patchflow-cli-docs/blob/main/docs/integrations/sarif.md"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "GitHub Repository",
            "href": "https://github.com/Patchflow-security/patchflow-cli"
          },
          {
            "label": "Report an Issue",
            "href": "https://github.com/Patchflow-security/patchflow-cli/issues"
          }
        ]
      }
    ]
  },
  "errors": {
    "404": {
      "redirect": true,
      "title": "Page not found",
      "description": "The page you're looking for doesn't exist. Use the search bar above or go back to the [home page](/)."
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:type": "website",
      "og:site_name": "PatchFlow CLI Documentation"
    }
  },
